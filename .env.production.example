# InternFlow production environment example
# Copy the relevant values into your frontend and API hosting provider dashboards.

# API service (Render/Railway/Fly/etc.)
NODE_ENV=production
PORT=4000
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/internflow?retryWrites=true&w=majority
JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
CORS_ORIGIN=https://your-frontend.pages.dev

# Frontend static host (Cloudflare Pages or Vercel)
VITE_API_URL=https://your-api-host.example.com/api

# Scheduled smoke checks / internal jobs
SMOKE_BASE_URL=https://your-frontend.pages.dev
SMOKE_API_URL=https://your-api-host.example.com
INTERNAL_JOB_SECRET=replace-with-32-random-characters

APP_URL=https://your-frontend.pages.dev
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_UPLOAD_PRESET=internflow-resumes
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=replace-me
SMTP_FROM="InternFlow <notifications@internflow.example>"
